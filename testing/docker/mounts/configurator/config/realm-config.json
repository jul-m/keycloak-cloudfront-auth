{
  "realm": "cloudfront-test",
  "enabled": true,
  "displayName": "CloudFront Test Realm",
  "accessTokenLifespan": 3600,
  "refreshTokenMaxReuse": 0,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "clients": [
    {
      "clientId": "cloudfront-test-client",
      "enabled": true,
      "secret": "TestSecret123",
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "publicClient": false,
      "protocol": "openid-connect",
      "redirectUris": [
        "http://localhost:8081/.cdn-auth/callback/*"
      ],
      "protocolMappers": [
        {
          "name": "cloudfront-auth-config",
          "protocol": "openid-connect",
          "protocolMapper": "fr.julm.keycloak.providers.auth.cloudfront.CloudFrontAuthConfigMapper",
          "consentRequired": false,
          "config": {
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ],
  "roles": {
    "client": {
      "cloudfront-test-client": [
        {
          "name": "cloudfront-access",
          "description": "Access role for CloudFront resources",
          "composite": false,
          "clientRole": true
        }
      ]
    }
  },
  "users": [
    {
      "username": "testuser",
      "enabled": true,
      "email": "testuser@example.com",
      "emailVerified": true,
      "firstName": "Test",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "testpassword",
          "temporary": false
        }
      ],
      "clientRoles": {
        "cloudfront-test-client": [
          "cloudfront-access"
        ]
      }
    }
  ]
}
