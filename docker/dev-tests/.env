## Environment variables for keycloak-cloudfront-auth docker-compose
# KCA_ prefixed vars are used to parameterize image/tag/ports and defaults
# Adjust values as needed before starting docker-compose

# Container Config: Keycloak
KCA_KC_HOST_PORT=8080

# Keycloak Base Config (setted directly by container env vars):
KCA_KC_ADMIN_USER=admin
KCA_KC_ADMIN_PASSWORD=admin
KCA_KC_AUTH_REDIRECT_DELAY=1
KCA_KC_AUTH_REDIRECT_FALLBACK_DELAY=2
KCA_KC_LOG_LEVEL=WARN,fr.julm:INFO

# Container Config: OpenResty
KCA_OPENRESTY_HOST_PORT=8081

# OpenResty Config:
KCA_DEBUG_PAGE_NO_AUTH=always  # always, never, or on_error
KCA_CF_SIGN_KEY_ID=ABCDEFGH
KCA_APP_URL=

# Test Env Config:
KCA_IMPORT_JSON_NAME=realm-config.json
KCA_KC_REALM_NAME=cloudfront-test
KCA_KC_CLIENT_ID=cloudfront-test-client
KCA_KC_CLIENT_SECRET=TestSecret123
